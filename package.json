    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "googleapis": "^173.0.0",
    "multer": "^2.2.0",
    "nunjucks": "^3.2.4",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/connect-flash": "^0.0.40",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/nunjucks": "^3.2.6",
